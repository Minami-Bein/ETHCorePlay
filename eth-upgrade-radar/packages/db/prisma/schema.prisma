generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

model Source { id String @id @default(cuid()) name String type String documents SourceDocument[] syncRuns SourceSyncRun[] }
model SourceDocument { id String @id @default(cuid()) sourceId String externalId String url String title String? rawFormat String rawPayload Json contentHash String? fetchedAt DateTime @default(now()) source Source @relation(fields:[sourceId],references:[id]) }
model SourceSyncRun { id String @id @default(cuid()) sourceId String status String startedAt DateTime @default(now()) finishedAt DateTime? source Source @relation(fields:[sourceId],references:[id]) }
model Upgrade { id String @id @default(cuid()) slug String @unique name String status String targetWindow String? readinessScore Float @default(0) confidenceScore Float @default(0) }
model Eip { id String @id @default(cuid()) number Int @unique title String status String inclusionStage String @default("none") }
model UpgradeEip { id String @id @default(cuid()) upgradeId String eipId String }
model Meeting { id String @id @default(cuid()) series String title String meetingAt DateTime }
model Discussion { id String @id @default(cuid()) kind String title String? url String }
model Client { id String @id @default(cuid()) name String layer String }
model ClientReadiness { id String @id @default(cuid()) clientId String upgradeId String status String evidenceRefs Json }
model Network { id String @id @default(cuid()) name String type String status String upgradeId String? }
model Event { id String @id @default(cuid()) type String title String sourceRef String occurredAt DateTime importanceScore Float @default(0) entityRefs Json }
model EntityAlias { id String @id @default(cuid()) entityType String canonical String alias String }
model EntityLink { id String @id @default(cuid()) documentId String entityType String entityId String confidence Float @default(1) }
model Subscription { id String @id @default(cuid()) channel String target String filter Json }
model Alert { id String @id @default(cuid()) type String payload Json createdAt DateTime @default(now()) }
model AlertDelivery { id String @id @default(cuid()) alertId String subscriptionId String status String deliveredAt DateTime? }
model UserWatchlist { id String @id @default(cuid()) userKey String entityType String entityId String }
